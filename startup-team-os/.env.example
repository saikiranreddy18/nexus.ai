# ── Provider ────────────────────────────────────────────────────────────────
# LLM_PROVIDER = openrouter | anthropic | openai | google | nvidia
# (leave unset → auto-picks the first provider that has a key)
# Tip: everything here can also be set live on the ⚙️ Settings page (/settings) —
# values saved there override these env vars, no restart needed.
LLM_PROVIDER=openrouter

# ── OpenRouter (any model) ──────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-your-key-here      # https://openrouter.ai/keys
# AGENT_MODEL examples (any OpenRouter model works):
#   openai/gpt-4o            anthropic/claude-opus-4-8        google/gemini-2.0-flash
#   meta-llama/llama-3.3-70b-instruct   deepseek/deepseek-chat   x-ai/grok-2
AGENT_MODEL=openai/gpt-4o
# OPENROUTER_REASONING=true   # only if AGENT_MODEL is a reasoning model that accepts an effort hint

# ── Anthropic (native) ──────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-your-key-here    # model e.g. claude-opus-4-8

# ── OpenAI (direct) ─────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-your-key-here           # model e.g. gpt-4o (Codex OAuth: roadmap)

# ── Google (Gemini) ─────────────────────────────────────────────────────────
# GOOGLE_API_KEY=AIza-your-key-here         # model e.g. gemini-2.0-flash

# ── NVIDIA NIM ──────────────────────────────────────────────────────────────
# NVIDIA_API_KEY=nvapi-your-key-here        # model e.g. meta/llama-3.3-70b-instruct
#                                           # free tier: https://build.nvidia.com

# ── Tuning (both providers) ─────────────────────────────────────────────────
AGENT_EFFORT=high             # low | medium | high | xhigh | max (Anthropic; OpenRouter reasoning models)
AGENT_MAX_TOKENS=24000        # per-agent output ceiling
LLM_TIMEOUT_MS=300000         # OpenRouter request timeout

# ── Server only ─────────────────────────────────────────────────────────────
PORT=3000
# RUN_API_KEY=some-long-random-string   # if set, /run and /run/stream require the key
