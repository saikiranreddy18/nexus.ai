# Set ONE of these API keys to enable the VC advisor:
# Priority: OPENROUTER > ANTHROPIC > OPENAI > NVIDIA

# NVIDIA (FREE - Recommended for you)
NVIDIA_API_KEY=nvapi-...
ORACLE_MODEL=meta/llama-3.1-8b-instruct
# Available models: meta/llama-3.1-8b-instruct, meta/llama-3.1-70b-instruct, etc.

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT-4)
OPENAI_API_KEY=sk-...

# OpenRouter (multi-model proxy)
OPENROUTER_API_KEY=sk-or-...
