{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "nexus-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "3d-office",
      "runtimeExecutable": "node",
      "runtimeArgs": ["server.mjs"],
      "cwd": "${workspaceFolder}/3d-office",
      "port": 3000
    },
    {
      "name": "startup-oracle",
      "runtimeExecutable": "node",
      "runtimeArgs": ["server.js"],
      "cwd": "${workspaceFolder}/startup-oracle",
      "port": 4100,
      "autoPort": true
    }
  ]
}
